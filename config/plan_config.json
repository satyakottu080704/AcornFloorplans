{
  "version": "1.0",
  "description": "Acorn Plan Generation Configuration",
  "ai": {
    "enabled": true,
    "provider_priority_vision": [
      "openai"
    ],
    "provider_priority_text": [
      "openai"
    ],
    "groq": {
      "enabled": false,
      "model": "llama-3.1-8b-instant",
      "max_retries": 2,
      "timeout": 30
    },
    "openai": {
      "enabled": true,
      "vision_model": "gpt-4o",
      "timeout": 60
    },
    "gemini": {
      "enabled": false,
      "requests_per_day": 1500
    },
    "ollama": {
      "enabled": false,
      "use_as_fallback": true,
      "url": "http://localhost:11434"
    },
    "plan_generation": {
      "enabled": true,
      "output_formats": [
        "vsdx",
        "pdf",
        "svg",
        "jpg",
        "drawio"
      ],
      "default_format": "vsdx",
      "color_scheme": {
        "acm_areas": "#FF0000",
        "no_access": "#0000FF",
        "cable_route": "#00FF00",
        "out_of_scope": "#808080",
        "sample_labels": "#FF0000"
      }
    }
  },
  "room_detection": {
    "strategies": [
      "dark_threshold",
      "adaptive_distance",
      "color_erasure",
      "watershed"
    ],
    "min_room_area": 500,
    "max_room_area_ratio": 0.5,
    "merge_iou_threshold": 0.3,
    "ocr_confidence_threshold": 0.6
  }
}

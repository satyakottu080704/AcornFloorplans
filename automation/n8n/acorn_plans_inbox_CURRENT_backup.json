        "id": "10cf8fdb-b16c-4ea4-ab1a-1766aba0e9a6",
        "name": "Get unread Plans emails",
        "webhookId": "f649f11e-c672-4691-b83d-5071570cda02",
        "credentials": {
          "microsoftOutlookOAuth2Api": {
            "id": "FNq1tabrcjylXbSd",
            "name": "Plans-Acornhealthandsafety"
          }
        }
      },
      {
        "parameters": {
          "jsCode": "// Pull the N-number from each plan email; drop emails without one.\nconst out = [];\nconst items = $input.all();\nfor (let i = 0; i < items.length; i++) {\n  const j = items[i].json;\n  const text = `${j.subject || ''} ${j.bodyPreview || ''}`;\n  const m = text.match(/N-\\d{4,10}/i);\n  if (!m) continue;\n  out.push({\n    json: { projectNumber: m[0].toUpperCase(), messageId: j.id, subject: j.subject || '' },\n    pairedItem: { item: i },\n  });\n}\nreturn out;"
        },
